@{
    string name = "";
    string username = "";
    string avatar = "";
    if (Request.Cookies["usr"] != null)
    {
        username = Request.Cookies["usr"].Value;
        name = Request.Cookies["Name"].Value;
    }
    if (Request.Cookies["avatar"] != null)
    {
        avatar = Request.Cookies["avatar"].Value;
    }
    else
    {
        avatar = Url.Content("~/Content/Img/macdinh.PNG");
    }
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>HuynhLuuKhoaShop - Admin CP</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet">
    <link href="~/Content/Admin/vendor/fontawesome-free/css/all.min.css" rel="stylesheet" />
    <link href="~/Content/Admin/vendor/datatables/dataTables.bootstrap4.min.css" rel="stylesheet" />
    <link href="~/Content/Admin/css/sb-admin-2.min.css" rel="stylesheet" />

    <style>
        body { font-family: 'Inter', sans-serif; }
        
        /* Tùy chỉnh Sidebar màu vàng sang trọng */
        #accordionSidebar {
            background: #aa8c55 !important; /* Màu vàng đồng chủ đạo */
            background: linear-gradient(180deg, #aa8c55 0%, #8b7142 100%) !important;
        }

        .sidebar-dark .nav-item .nav-link { font-weight: 500; opacity: 0.9; }
        .sidebar-dark .nav-item .nav-link:hover { opacity: 1; background: rgba(255,255,255,0.1); }
        
        /* Bo góc các submenu trắng */
        .collapse-inner {
            border-radius: 12px !important;
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
            border: none !important;
        }
        
        .collapse-item:active { background-color: #aa8c55 !important; }

        /* Topbar & Content */
        .topbar { background-color: #fff !important; }
        .sticky-footer { background: #fff !important; border-top: 1px solid #eee; }
        
        /* Avatar & User info */
        .img-profile { object-fit: cover; border: 2px solid #aa8c55; }
    </style>
</head>

<body id="page-top">

    <div id="wrapper">
        <ul class="navbar-nav sidebar sidebar-dark accordion" id="accordionSidebar">
            
            <a class="sidebar-brand d-flex align-items-center justify-content-center" href="@Url.Action("Index","Admin")" style="margin: 20px 0;">
                <div class="sidebar-brand-icon rotate-n-15">
                    <i class="fas fa-laugh-wink" style="font-size: 2rem;"></i>
                </div>
                <div class="sidebar-brand-text mx-3" style="font-weight: 700; letter-spacing: 1px;">HuynhLuuKhoa Admin</div>
            </a>

            <hr class="sidebar-divider my-0" style="opacity: 0.2;">

            <li class="nav-item">
                <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#da">
                    <i class="fas fa-fw fa-cube"></i>
                    <span>Sản Phẩm</span>
                </a>
                <div id="da" class="collapse" data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner">
                        <a class="collapse-item" href="@Url.Action("Index","Items")">Danh sách</a>
                        <a class="collapse-item" href="@Url.Action("Index","ItemTypes")">Loại sản phẩm</a>
                    </div>
                </div>
            </li>

            <li class="nav-item">
                <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#rr2">
                    <i class="fas fa-shopping-cart"></i>
                    <span>Đơn hàng</span>
                </a>
                <div id="rr2" class="collapse" data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner">
                        <a class="collapse-item" href="@Url.Action("AllListOrder","Admin")">Danh sách tất cả</a>
                        <a class="collapse-item" href="@Url.Action("ListOrder","Admin")">Chờ xử lý</a>
                    </div>
                </div>
            </li>

            <li class="nav-item">
                <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#collapsePages">
                    <i class="fas fa-fw fa-user"></i>
                    <span>Khách Hàng</span>
                </a>
                <div id="collapsePages" class="collapse" data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner">
                        <a class="collapse-item" href="@Url.Action("Index","Customers")">Danh sách khách</a>
                    </div>
                </div>
            </li>

            <li class="nav-item">
                <a class="nav-link collapsed" href="#" data-toggle="collapse" data-target="#report">
                    <i class="fas fa-fw fa-chart-line"></i>
                    <span>Thống kê</span>
                </a>
                <div id="report" class="collapse" data-parent="#accordionSidebar">
                    <div class="bg-white py-2 collapse-inner">
                        <a class="collapse-item" href="@Url.Action("Index","Summary")">Doanh thu theo loại</a>
                    </div>
                </div>
            </li>

            <hr class="sidebar-divider d-none d-md-block" style="opacity: 0.1;">

            <div class="text-center d-none d-md-inline">
                <button class="rounded-circle border-0" id="sidebarToggle" style="background: rgba(255,255,255,0.2);"></button>
            </div>
        </ul>
        <div id="content-wrapper" class="d-flex flex-column" style="background-color: #f8f9fc;">
            <div id="content">
                <nav class="navbar navbar-expand navbar-light topbar mb-4 static-top shadow-sm">
                    <button id="sidebarToggleTop" class="btn btn-link d-md-none rounded-circle mr-3">
                        <i class="fa fa-bars" style="color: #aa8c55;"></i>
                    </button>

                    <h1 class="h4 mb-0 text-gray-800 d-none d-sm-block" style="font-weight: 600;">Hệ thống quản lý</h1>

                    <ul class="navbar-nav ml-auto">
                        <li class="nav-item dropdown no-arrow">
                            <a class="nav-link dropdown-toggle" href="#" id="userDropdown" data-toggle="dropdown">
                                <span class="mr-2 d-none d-lg-inline text-gray-600 small">Chào, <b>@name</b></span>
                                <img class="img-profile rounded-circle" width="35" height="35" src="@Url.Content(avatar)">
                            </a>
                            <div class="dropdown-menu dropdown-menu-right shadow animated--grow-in">
                                <a class="dropdown-item" href="~/Admin/SignOut">
                                    <i class="fas fa-sign-out-alt fa-sm fa-fw mr-2 text-gray-400"></i>
                                    Đăng xuất
                                </a>
                            </div>
                        </li>
                    </ul>
                </nav>

                <div class="container-fluid" style="min-height: 80vh;">
                    @RenderBody()
                </div>
            </div>

            <footer class="sticky-footer">
                <div class="container my-auto">
                    <div class="copyright text-center my-auto">
                        <span style="color: #999;">&copy; @DateTime.Now.Year - Phát triển bởi <b style="color: #aa8c55;">Lưu Khoa</b></span>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <a class="scroll-to-top rounded-circle" href="#page-top" style="background: #aa8c55;">
        <i class="fas fa-angle-up"></i>
    </a>

    <script src="~/Content/Admin/vendor/jquery/jquery.min.js"></script>
    <script src="~/Content/Admin/vendor/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/Content/Admin/vendor/jquery-easing/jquery.easing.min.js"></script>
    <script src="~/Content/Admin/js/sb-admin-2.min.js"></script>
    <script src="~/Content/Admin/vendor/datatables/jquery.dataTables.min.js"></script>
    <script src="~/Content/Admin/vendor/datatables/dataTables.bootstrap4.min.js"></script>

    @RenderSection("upload", required: false)
    @RenderSection("scripts", required: false)
</body>
</html>